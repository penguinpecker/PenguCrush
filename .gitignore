# ═══════════════════════════════════════════════════
# PenguCrush .gitignore — Web2 + Web3 Security
# ═══════════════════════════════════════════════════

# ── Environment & Secrets ──────────────────────────
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
*.env
.secret
.secrets
*.key
*.pem
*.p12
*.pfx
*.keystore

# ── Private Keys & Wallets ─────────────────────────
# NEVER commit private keys, mnemonics, or keystores
privatekey*
private_key*
mnemonic*
seed_phrase*
keystore/
wallet.json
deployer.json
*.seed

# ── Hardhat / zkSync Artifacts ─────────────────────
artifacts/
cache/
cache-zk/
artifacts-zk/
typechain/
typechain-types/
zkout/
deployments-zk/

# ── Node / npm ─────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json

# ── Build Output ───────────────────────────────────
dist/
build/
.output/
.vercel/
.netlify/

# ── IDE / Editor ───────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Supabase Local ─────────────────────────────────
supabase/.temp/
supabase/.branches/
supabase/.linked

# ── Coverage & Testing ─────────────────────────────
coverage/
.nyc_output/
lcov.info

# ── Logs ───────────────────────────────────────────
*.log
logs/

# ── OS Files ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# local backup of uncompressed assets (not shipped)
public/assets_ORIGINAL/
